---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Tao Gaetz"
  description="Tao Gaetz is a software developer in Montreal building web software."
>
  <main class="px-8 py-8 sm:px-10 sm:py-10">
    <h1 class="m-0 text-3xl font-medium tracking-tight text-transparent bg-clip-text bg-[image:radial-gradient(circle_at_20%_20%,rgba(0,0,0,0.034)_0,rgba(0,0,0,0.034)_0.4px,transparent_0.5px),linear-gradient(180deg,rgba(17,17,17,0.96),rgba(17,17,17,0.9))] [text-shadow:0_1px_0_rgba(255,255,255,0.26),0_-1px_0_rgba(0,0,0,0.022)]">Tao Gaetz</h1>
    <p class="m-0 text-base text-transparent bg-clip-text bg-[image:radial-gradient(circle_at_24%_32%,rgba(0,0,0,0.028)_0,rgba(0,0,0,0.028)_0.4px,transparent_0.5px),linear-gradient(180deg,rgba(24,24,24,0.94),rgba(24,24,24,0.88))] [text-shadow:0_1px_0_rgba(255,255,255,0.22),0_-1px_0_rgba(0,0,0,0.02)]">Software developer in Montreal.</p>
    <p class="m-0 text-base text-transparent bg-clip-text bg-[image:radial-gradient(circle_at_24%_32%,rgba(0,0,0,0.028)_0,rgba(0,0,0,0.028)_0.4px,transparent_0.5px),linear-gradient(180deg,rgba(24,24,24,0.94),rgba(24,24,24,0.88))] [text-shadow:0_1px_0_rgba(255,255,255,0.22),0_-1px_0_rgba(0,0,0,0.02)]">Building ChefBible, Redbackpack, and other web software.</p>
    <address class="m-0 not-italic text-base text-transparent bg-clip-text bg-[image:radial-gradient(circle_at_24%_32%,rgba(0,0,0,0.024)_0,rgba(0,0,0,0.024)_0.35px,transparent_0.45px),linear-gradient(180deg,rgba(24,24,24,0.92),rgba(24,24,24,0.86))] [text-shadow:0_1px_0_rgba(255,255,255,0.2),0_-1px_0_rgba(0,0,0,0.018)]">
      <a class="text-transparent bg-clip-text bg-[image:inherit] underline decoration-black/30 underline-offset-[0.12em]" href="mailto:tao@taogaetz.com">tao@taogaetz.com</a> · <a class="text-transparent bg-clip-text bg-[image:inherit] underline decoration-black/30 underline-offset-[0.12em]" href="https://github.com/taogaetz">GitHub</a> · <a class="text-transparent bg-clip-text bg-[image:inherit] underline decoration-black/30 underline-offset-[0.12em]" href="https://linkedin.com/in/taogaetz">LinkedIn</a>
    </address>
  </main>
</Layout>

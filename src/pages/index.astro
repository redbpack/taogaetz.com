---
import Layout from '../layouts/Layout.astro';

const links = [
  {
    name: 'Redbackpack',
    tagline: 'Studio',
    description: 'Production websites and cleanup work for small businesses.',
    url: 'https://redbackpack.ca',
    label: 'redbackpack.ca',
  },
  {
    name: 'ChefBible',
    tagline: 'Product',
    description: 'Kitchen software built from actual service pressure, not a Figma fantasy.',
    url: 'https://chefbible.com',
    label: 'chefbible.com',
  },
  {
    name: 'GitHub',
    tagline: 'Code',
    description: 'Public repos, experiments, and the parts worth showing.',
    url: 'https://github.com/taogaetz',
    label: 'github.com/taogaetz',
  },
];
---

<Layout>
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-[60] focus:bg-[#eddcbc] focus:text-[#130b06] focus:px-3 focus:py-2 focus:border-2 focus:border-[#5c3a28]">
    Skip to content
  </a>

  <nav aria-label="Primary" class="fixed top-0 left-0 right-0 z-50 bg-[#130b06] border-b-2 border-[#3d2316]">
    <div class="max-w-4xl mx-auto px-6 h-11 flex items-center justify-between font-mono text-sm">
      <a href="#top" class="text-[#d4502a] font-bold hover:text-[#eddcbc] transition-colors">tao gaetz</a>
      <div class="flex items-center">
        <a href="#links" class="px-4 h-11 flex items-center text-[#8a6a52] hover:text-[#130b06] hover:bg-[#eddcbc] transition-colors border-l-2 border-[#3d2316]">links</a>
        <a href="mailto:tao@taogaetz.com" class="px-4 h-11 flex items-center text-[#130b06] bg-[#d4502a] font-bold border-l-2 border-[#3d2316] hover:bg-[#b83e1e] transition-colors">contact</a>
      </div>
    </div>
  </nav>

  <main id="main-content">
    <header id="top" class="max-w-4xl mx-auto px-6 pt-20 sm:pt-28 pb-16">
      <div class="border-2 border-[#5c3a28] shadow-[6px_6px_0px_#d4502a] p-8 mb-10 bg-[#1a0e07]">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6">
          <figure class="flex-shrink-0 w-fit sm:order-2">
            <div class="border-2 border-[#5c3a28] shadow-[4px_4px_0px_#c8922a] w-fit">
              <img src="/headshot.webp" alt="Portrait of Tao Gaetz" width="256" height="256" class="w-24 h-24 sm:w-32 sm:h-32 object-cover grayscale block" />
            </div>
            <figcaption class="font-mono text-xs text-[#4a2c1a] mt-1 text-center">tao.jpg</figcaption>
          </figure>

          <div class="sm:order-1">
            <h1 class="font-mono text-5xl sm:text-6xl font-bold tracking-tight text-[#eddcbc] mb-1 leading-none uppercase">
              TAO GAETZ
            </h1>
            <p class="font-mono text-base text-[#d4502a] mb-6">software developer — montreal, qc</p>

            <p class="font-mono text-sm text-[#8a6a52] leading-relaxed max-w-lg mb-8">
              Self-taught developer building production web software, self-hosted infrastructure, and AI-adjacent tools. Strong on systems, product sense, and shipping under pressure. Looking for a team that moves fast and builds seriously.
            </p>

            <div class="flex flex-wrap gap-3">
              <a href="https://github.com/taogaetz" target="_blank" rel="noopener noreferrer"
                class="font-mono text-sm px-4 py-2 border-2 border-[#5c3a28] text-[#eddcbc] hover:bg-[#eddcbc] hover:text-[#130b06] hover:border-[#eddcbc] transition-colors shadow-[3px_3px_0px_#3d2316]">
                GitHub
              </a>
              <a href="https://linkedin.com/in/taogaetz" target="_blank" rel="noopener noreferrer"
                class="font-mono text-sm px-4 py-2 border-2 border-[#5c3a28] text-[#eddcbc] hover:bg-[#eddcbc] hover:text-[#130b06] hover:border-[#eddcbc] transition-colors shadow-[3px_3px_0px_#3d2316]">
                LinkedIn
              </a>
              <a href="#links"
                class="font-mono text-sm px-4 py-2 border-2 border-[#d4502a] bg-[#d4502a] text-[#130b06] font-bold hover:bg-[#b83e1e] hover:border-[#b83e1e] transition-colors shadow-[3px_3px_0px_#7a2010]">
                View Links →
              </a>
            </div>
          </div>
        </div>
      </div>

      <section aria-label="Summary" class="grid grid-cols-1 sm:grid-cols-3 border-2 border-[#5c3a28] bg-[#1a0e07]">
        <div class="px-5 py-4 border-b-2 sm:border-b-0 sm:border-r-2 border-[#3d2316]">
          <h2 class="font-mono text-xs text-[#c8922a] uppercase tracking-widest mb-2">Background</h2>
          <p class="font-mono text-xs text-[#8a6a52] leading-relaxed">
            Designer → self-taught developer → bootcamp → GCP support → chef de partie → software. Deliberate path, not an accident.
          </p>
        </div>
        <div class="px-5 py-4 border-b-2 sm:border-b-0 sm:border-r-2 border-[#3d2316]">
          <h2 class="font-mono text-xs text-[#c8922a] uppercase tracking-widest mb-2">Focus</h2>
          <p class="font-mono text-xs text-[#8a6a52] leading-relaxed">
            Shipping useful software, strong product taste, and clean execution.
          </p>
        </div>
        <div class="px-5 py-4">
          <h2 class="font-mono text-xs text-[#c8922a] uppercase tracking-widest mb-2">Currently</h2>
          <p class="font-mono text-xs text-[#8a6a52] leading-relaxed">
            Building ChefBible, running Redbackpack, and open to the right team.
          </p>
        </div>
      </section>
    </header>

    <section id="links" class="max-w-4xl mx-auto px-6 pb-20" aria-labelledby="links-heading">
      <h2 id="links-heading" class="font-mono text-xs text-[#c8922a] uppercase tracking-widest mb-6">Links</h2>

      <div class="space-y-5">
        {links.map((link) => (
          <article class="border-2 border-[#5c3a28] bg-[#1a0e07] shadow-[5px_5px_0px_#d4502a] hover:shadow-[5px_5px_0px_#c8922a] transition-shadow p-6">
            <div class="flex items-start justify-between mb-3 gap-4">
              <div>
                <h3>
                  <a href={link.url} target="_blank" rel="noopener noreferrer" class="font-mono text-xl font-bold text-[#eddcbc] uppercase hover:text-[#d4502a] transition-colors">{link.name}</a>
                </h3>
                <p class="font-mono text-sm text-[#c8922a]">{link.tagline}</p>
              </div>
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="font-mono text-xs px-2 py-1 border-2 border-[#d4502a] text-[#d4502a] font-bold flex-shrink-0 mt-1 hover:bg-[#d4502a] hover:text-[#130b06] transition-colors">
                Visit →
              </a>
            </div>
            <p class="font-mono text-xs text-[#8a6a52] leading-relaxed mb-4">{link.description}</p>
            <p class="font-mono text-[10px] uppercase tracking-widest text-[#4a2c1a]">{link.label}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="max-w-4xl mx-auto px-6 pb-20" aria-labelledby="contact-heading">
      <div class="border-2 border-[#5c3a28] bg-[#1a0e07] shadow-[5px_5px_0px_#d4502a] p-8">
        <h2 id="contact-heading" class="font-mono text-2xl font-bold text-[#eddcbc] uppercase mb-2">Let's work together</h2>
        <p class="font-mono text-xs text-[#8a6a52] mb-6 max-w-md leading-relaxed">
          Open to full-time roles, contract work, or interesting problems. Montreal-based. Remote or hybrid.
        </p>
        <a href="mailto:tao@taogaetz.com"
          class="inline-block font-mono text-sm px-6 py-3 bg-[#d4502a] text-[#130b06] font-bold border-2 border-[#d4502a] hover:bg-[#b83e1e] hover:border-[#b83e1e] transition-colors shadow-[3px_3px_0px_#7a2010]">
          tao@taogaetz.com →
        </a>
      </div>
    </section>
  </main>

  <footer class="border-t-2 border-[#3d2316] bg-[#130b06]">
    <div class="max-w-4xl mx-auto px-6 h-10 flex items-center justify-between font-mono text-xs text-[#3d2316]">
      <span>taogaetz.com</span>
      <span>montreal, qc · <span class="text-[#d4502a]">available</span></span>
    </div>
  </footer>
</Layout>

---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Tao Gaetz — Software Developer',
  description = 'Montreal software developer building production web software, self-hosted infrastructure, and AI-adjacent tools.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Tao Gaetz" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://taogaetz.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href="https://taogaetz.com" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
      href="https://fonts.googleapis.com/css2?family=Fira+Sans:wght@400;500&display=swap"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fira+Sans:wght@400;500&display=swap"
      />
    </noscript>
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-stone-50 text-stone-950 font-[\'Fira_Sans\',system-ui,sans-serif] [background-image:radial-gradient(circle_at_20%_20%,rgba(0,0,0,0.012)_0,rgba(0,0,0,0.012)_0.7px,transparent_0.8px),radial-gradient(circle_at_80%_30%,rgba(0,0,0,0.01)_0,rgba(0,0,0,0.01)_0.6px,transparent_0.7px),radial-gradient(circle_at_40%_70%,rgba(0,0,0,0.008)_0,rgba(0,0,0,0.008)_0.6px,transparent_0.7px)] [background-size:19px_19px,23px_23px,29px_29px]">
    <slot />
  </body>
</html>
